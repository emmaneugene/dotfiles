def main() -> int:
    parser = argparse.ArgumentParser(
        description="Display status codes for various standards.",
    )
    parser.add_argument(
        "standard",
        choices=list(CODES.keys()),
        metavar="standard",
        help="Standard to display. Choices: " + ", ".join(CODES.keys()),
    )
    argcomplete.autocomplete(parser)
    args = parser.parse_args()

    print(CODES[args.standard])
    return 0


if __name__ == "__main__":
    sys.exit(main())
