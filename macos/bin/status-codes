#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["argcomplete"]
# ///
# PYTHON_ARGCOMPLETE_OK

"""
Display status codes for various standards.
Usage: status-codes <standard>

Supported standards: process-exits, http, grpc, dns
Example: status-codes http
"""

import argparse
import os
import signal
import sys
from typing import Dict

import argcomplete

SYSEXITS: Dict[str, str] = {
    "EX_OK": "Success",
    "EX_USAGE": "Command line usage error",
    "EX_DATAERR": "Input data error",
    "EX_NOINPUT": "Cannot open input",
    "EX_NOUSER": "Addressee unknown",
    "EX_NOHOST": "Host name unknown",
    "EX_UNAVAILABLE": "Service unavailable",
    "EX_SOFTWARE": "Internal software error",
    "EX_OSERR": "System error",
    "EX_OSFILE": "Critical OS file missing",
    "EX_CANTCREAT": "Can't create output file",
    "EX_IOERR": "Input/output error",
    "EX_TEMPFAIL": "Temporary failure; retry later",
    "EX_PROTOCOL": "Remote protocol error",
    "EX_NOPERM": "Permission denied",
    "EX_CONFIG": "Configuration error",
}


def process_exit_codes() -> str:
    """Build common process exit codes for the current platform."""
    codes: Dict[int, str] = {
        0: "Success / EX_OK",
        1: "General error",
        2: "Misuse of shell command",
        126: "Command invoked cannot execute",
        127: "Command not found",
    }

    for name, description in SYSEXITS.items():
        if name == "EX_OK" or not hasattr(os, name):
            continue
        codes[getattr(os, name)] = f"{name} {description}"

    for sig in sorted(signal.Signals, key=lambda s: s.value):
        if sig.value <= 0:
            continue
        desc = signal.strsignal(sig.value) or "Signal"
        suffix = f": {sig.value}"
        if desc.endswith(suffix):
            desc = desc[: -len(suffix)]
        if sig == signal.SIGINT:
            desc = f"{desc} / Ctrl+C"
        codes[128 + sig.value] = f"{sig.name} ({desc})"

    return "\n".join(f"{code} {label}" for code, label in sorted(codes.items()))


