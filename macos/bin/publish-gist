#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# ///
"""Publish Markdown files to GitHub Gists with embedded local images."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import urllib.parse
import webbrowser
from dataclasses import dataclass
from pathlib import Path

COMMANDS = {"doctor", "scan", "publish"}


class CliError(Exception):
    def __init__(
        self, message: str, *, exit_code: int = 1, details: dict | None = None
    ):
        super().__init__(message)
        self.message = message
        self.exit_code = exit_code
        self.details = details or {}


@dataclass
class Asset:
    source: str
    decoded: str
    status: str
    path: str | None = None
    gist_filename: str | None = None
    warning: str | None = None

    def to_dict(self) -> dict:
        return {
            "source": self.source,
            "decoded": self.decoded,
            "status": self.status,
            "path": self.path,
            "gist_filename": self.gist_filename,
            "warning": self.warning,
        }


@dataclass
class PublishPlan:
    markdown_path: Path
    gist_filename: str
    content: str
    assets: list[Asset]

    @property
    def warnings(self) -> list[str]:
        return [asset.warning for asset in self.assets if asset.warning]

    @property
    def resolved_assets(self) -> list[Asset]:
        return [asset for asset in self.assets if asset.status == "resolved"]

    def to_dict(self) -> dict:
        return {
            "markdown_path": str(self.markdown_path),
            "gist_filename": self.gist_filename,
            "asset_count": len(self.assets),
            "resolved_asset_count": len(self.resolved_assets),
            "warning_count": len(self.warnings),
            "assets": [asset.to_dict() for asset in self.assets],
            "warnings": self.warnings,
        }


def run(
    cmd: list[str],
    *,
    cwd: str | None = None,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    result = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)
    if check and result.returncode != 0:
        raise CliError(
            f"Command failed: {' '.join(cmd)}",
            details={
                "command": cmd,
                "stdout": result.stdout.strip(),
                "stderr": result.stderr.strip(),
                "returncode": result.returncode,
            },
        )
    return result


def normalize_args(argv: list[str]) -> tuple[list[str], bool]:
    json_output = False
    if argv and argv[0] == "--json":
        json_output = True
        argv = argv[1:]

    if argv and argv[0] not in COMMANDS and not argv[0].startswith("-"):
        argv = ["publish", *argv]

    return argv, json_output


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="publish-gist",
        description="Publish Markdown files to GitHub Gists with embedded local images.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Typical workflow:\n"
            "  publish-gist doctor                       # check gh CLI and authentication\n"
            "  publish-gist scan report.md               # preview asset resolution without publishing\n"
            "  publish-gist publish --dry-run report.md  # full dry run\n"
            "  publish-gist publish report.md --web      # publish and open in browser"
        ),
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    doctor_parser = subparsers.add_parser(
        "doctor",
        help="Check local prerequisites and GitHub auth",
        description="Verify that gh and git are installed, gh is authenticated, and the token has the 'gist' OAuth scope.",
    )
    doctor_parser.add_argument(
        "--json",
        action="store_true",
        dest="json_output",
        help="Emit machine-readable JSON",
    )

    scan_parser = subparsers.add_parser(
        "scan",
        help="Inspect a Markdown file and resolve local assets without publishing",
        description="Resolve all local image references in the Markdown file and show which assets would be uploaded as gist attachments, without creating a gist.",
    )
    add_common_publish_args(scan_parser)
    scan_parser.add_argument(
        "--json",
        action="store_true",
        dest="json_output",
        help="Emit machine-readable JSON",
    )

    publish_parser = subparsers.add_parser(
        "publish",
        help="Create or preview a gist for a Markdown file",
        description="Create a GitHub Gist from a Markdown file, uploading any local images as gist attachments and rewriting their URLs to point at the raw gist content. Use --dry-run to preview without creating.",
    )
    add_common_publish_args(publish_parser)
    publish_parser.add_argument(
        "--public",
        action="store_true",
        help="Create a public gist instead of a secret gist",
    )
    publish_parser.add_argument(
        "--desc",
        help="Description to set on the gist",
    )
    publish_parser.add_argument(
        "--web",
        action="store_true",
        help="Open the created gist in the browser",
    )
    publish_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be published without creating a gist",
    )
    publish_parser.add_argument(
        "--json",
        action="store_true",
        dest="json_output",
        help="Emit machine-readable JSON",
    )

    return parser


def add_common_publish_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("markdown_file", help="Path to the Markdown file")
    parser.add_argument(
        "--name",
        help=(
            "Custom filename for the Markdown file in the gist. "
            "'.md' is appended if missing."
        ),
    )


def emit_text(data: dict) -> None:
    command = data.get("command")
    if command == "doctor":
        print(f"Overall: {'ok' if data['ok'] else 'not ok'}")
        for check in data["checks"]:
            line = f"- {check['name']}: {'ok' if check['ok'] else 'missing'}"
            if check.get("detail"):
                line += f" ({check['detail']})"
            print(line)
        return

    if command == "scan":
        print(f"Markdown: {data['markdown_path']}")
        print(f"Gist filename: {data['gist_filename']}")
        print(f"Resolved assets: {data['resolved_asset_count']}/{data['asset_count']}")
        for asset in data["assets"]:
            line = f"- {asset['source']}: {asset['status']}"
            if asset.get("gist_filename"):
                line += f" -> {asset['gist_filename']}"
            print(line)
        for warning in data["warnings"]:
            print(f"Warning: {warning}", file=sys.stderr)
        return

    if command == "publish":
        if data.get("dry_run"):
            print("Dry run only. No gist was created.")
            emit_text(data["plan"])
            return

        print(f"Gist URL: {data['gist_url']}")
        print(f"Gist ID: {data['gist_id']}")
        print(f"Visibility: {'public' if data['public'] else 'secret'}")
        print(f"Embedded assets: {data['embedded_asset_count']}")
        return

    raise CliError(f"Unknown output command: {command}")


def emit_result(data: dict, *, json_output: bool) -> None:
    if json_output:
        print(json.dumps(data, indent=2, sort_keys=True))
    else:
        emit_text(data)


def emit_error(error: CliError, *, json_output: bool) -> None:
    if json_output:
        payload = {
            "ok": False,
            "error": {
                "message": error.message,
                "details": error.details,
            },
        }
        print(json.dumps(payload, indent=2, sort_keys=True), file=sys.stderr)
    else:
        print(f"Error: {error.message}", file=sys.stderr)
        stderr = error.details.get("stderr")
        if stderr:
            print(stderr, file=sys.stderr)


def doctor() -> dict:
    checks = []

    for command_name in ("gh", "git"):
        path = shutil.which(command_name)
        checks.append(
            {
                "name": command_name,
                "ok": bool(path),
                "detail": path,
            }
        )

    auth_result = subprocess.run(
        ["gh", "auth", "status"],
        capture_output=True,
        text=True,
    )
    auth_text = "\n".join(
        part.strip()
        for part in (auth_result.stdout, auth_result.stderr)
        if part.strip()
    )

    login_match = re.search(r"Logged in to github\.com account ([^\s]+)", auth_text)
    scopes_match = re.search(r"Token scopes:\s*(.+)", auth_text)
    scopes = []
    if scopes_match:
        raw_scopes = scopes_match.group(1).strip().strip("'")
        scopes = [
            scope.strip().strip("'") for scope in raw_scopes.split(",") if scope.strip()
        ]

    checks.append(
        {
            "name": "gh_auth",
            "ok": auth_result.returncode == 0,
            "detail": login_match.group(1) if login_match else None,
            "auth_source": "gh_cli",
            "scopes": scopes,
            "has_gist_scope": "gist" in scopes,
        }
    )

    ok = (
        all(check["ok"] for check in checks[:-1])
        and checks[-1]["ok"]
        and checks[-1]["has_gist_scope"]
    )
    return {
        "ok": ok,
        "command": "doctor",
        "checks": checks,
    }


def build_gist_filename(markdown_path: Path, custom_name: str | None) -> str:
    gist_name = custom_name or markdown_path.name
    if not gist_name.endswith(".md"):
        gist_name += ".md"
    utc_prefix = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H%M%SZ-")
    return utc_prefix + gist_name


def find_local_image_refs(content: str) -> list[str]:
    refs = []
    for match in re.finditer(r"!\[[^\]]*\]\(([^)]+)\)", content):
        path = match.group(1)
        if not path.startswith(("http://", "https://")):
            refs.append(path)

    for match in re.finditer(
        r'<img[^>]+src=["\']([^"\']+)["\']', content, re.IGNORECASE
    ):
        path = match.group(1)
        if not path.startswith(("http://", "https://")):
            refs.append(path)

    unique_refs = []
    seen = set()
    for ref in refs:
        if ref not in seen:
            seen.add(ref)
            unique_refs.append(ref)
    return unique_refs


def sanitize_filename(path: str, taken: set[str]) -> str:
    base = "_" + os.path.basename(path).replace(" ", "-")
    if base not in taken:
        taken.add(base)
        return base

    name, ext = os.path.splitext(base)
    counter = 2
    while f"{name}-{counter}{ext}" in taken:
        counter += 1

    result = f"{name}-{counter}{ext}"
    taken.add(result)
    return result


def build_plan(markdown_file: str, custom_name: str | None) -> PublishPlan:
    markdown_path = Path(markdown_file).expanduser().resolve()
    if not markdown_path.is_file():
        raise CliError(f"File not found: {markdown_file}")

    content = markdown_path.read_text(encoding="utf-8")
    gist_filename = build_gist_filename(markdown_path, custom_name)
    taken_names: set[str] = set()
    assets: list[Asset] = []

    for ref in find_local_image_refs(content):
        decoded_ref = urllib.parse.unquote(ref)
        full_path = (markdown_path.parent / decoded_ref).resolve()

        try:
            full_path.relative_to(markdown_path.parent)
        except ValueError:
            assets.append(
                Asset(
                    source=ref,
                    decoded=decoded_ref,
                    status="outside_root",
                    warning=f"Referenced image outside markdown directory: {ref}",
                )
            )
            continue

        if not full_path.is_file():
            assets.append(
                Asset(
                    source=ref,
                    decoded=decoded_ref,
                    status="missing",
                    path=str(full_path),
                    warning=f"Referenced image not found: {ref}",
                )
            )
            continue

        assets.append(
            Asset(
                source=ref,
                decoded=decoded_ref,
                status="resolved",
                path=str(full_path),
                gist_filename=sanitize_filename(decoded_ref, taken_names),
            )
        )

    return PublishPlan(
        markdown_path=markdown_path,
        gist_filename=gist_filename,
        content=content,
        assets=assets,
    )


def rewrite_markdown(
    content: str, gist_id: str, owner: str, assets: list[Asset]
) -> str:
    rewritten = content
    for asset in assets:
        encoded_name = urllib.parse.quote(asset.gist_filename or "")
        raw_url = (
            f"https://gist.githubusercontent.com/{owner}/{gist_id}/raw/{encoded_name}"
        )
        escaped_ref = re.escape(asset.source)
        rewritten = re.sub(
            rf"(!\[[^\]]*\]\()({escaped_ref})(\))",
            rf"\1{raw_url}\3",
            rewritten,
        )
        rewritten = re.sub(
            rf"(<img[^>]+src=[\"\'])({escaped_ref})([\"\'])",
            rf"\1{raw_url}\3",
            rewritten,
            flags=re.IGNORECASE,
        )
    return rewritten


def do_scan(args: argparse.Namespace) -> dict:
    plan = build_plan(args.markdown_file, args.name)
    return {
        "ok": True,
        "command": "scan",
        **plan.to_dict(),
    }


def ensure_ready_to_publish() -> None:
    result = doctor()
    if result["ok"]:
        return
    raise CliError(
        "publish-gist doctor failed",
        details={"doctor": result},
    )


def do_publish(args: argparse.Namespace) -> dict:
    plan = build_plan(args.markdown_file, args.name)

    if args.dry_run:
        return {
            "ok": True,
            "command": "publish",
            "dry_run": True,
            "plan": {
                "ok": True,
                "command": "scan",
                **plan.to_dict(),
            },
            "public": bool(args.public),
            "description": args.desc,
        }

    ensure_ready_to_publish()

    with tempfile.TemporaryDirectory() as staging:
        staged_md = Path(staging) / plan.gist_filename
        shutil.copy2(plan.markdown_path, staged_md)

        create_cmd = ["gh", "gist", "create"]
        if args.public:
            create_cmd.append("--public")
        if args.desc:
            create_cmd.extend(["--desc", args.desc])
        create_cmd.append(str(staged_md))

        gist_url = run(create_cmd).stdout.strip()

    if "gist.github.com" not in gist_url:
        raise CliError(
            "Unexpected response from gh gist create",
            details={"gist_url": gist_url},
        )

    gist_id = gist_url.rstrip("/").split("/")[-1]

    if plan.resolved_assets:
        clone_dir = Path(tempfile.mkdtemp())
        try:
            run(["gh", "gist", "clone", gist_id, str(clone_dir)])

            for asset in plan.resolved_assets:
                shutil.copy2(asset.path, clone_dir / (asset.gist_filename or ""))

            run(["git", "add", "."], cwd=str(clone_dir))
            run(["git", "commit", "-m", "Add images"], cwd=str(clone_dir))
            run(["git", "push"], cwd=str(clone_dir))

            gist_json = json.loads(run(["gh", "api", f"gists/{gist_id}"]).stdout)
            owner = gist_json.get("owner", {}).get("login", "")

            rewritten = rewrite_markdown(
                plan.content, gist_id, owner, plan.resolved_assets
            )
            rewritten_path = clone_dir / plan.gist_filename
            rewritten_path.write_text(rewritten, encoding="utf-8")
            run(
                [
                    "gh",
                    "gist",
                    "edit",
                    gist_id,
                    "-f",
                    plan.gist_filename,
                    str(rewritten_path),
                ]
            )
        finally:
            shutil.rmtree(clone_dir, ignore_errors=True)

    if args.web:
        webbrowser.open(gist_url)

    return {
        "ok": True,
        "command": "publish",
        "dry_run": False,
        "gist_url": gist_url,
        "gist_id": gist_id,
        "public": bool(args.public),
        "description": args.desc,
        "embedded_asset_count": len(plan.resolved_assets),
        "warning_count": len(plan.warnings),
        "warnings": plan.warnings,
        "markdown_path": str(plan.markdown_path),
        "gist_filename": plan.gist_filename,
    }


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    argv, global_json_output = normalize_args(argv)
    parser = build_parser()
    args = parser.parse_args(argv)
    json_output = global_json_output or getattr(args, "json_output", False)

    try:
        if args.command == "doctor":
            result = doctor()
        elif args.command == "scan":
            result = do_scan(args)
        elif args.command == "publish":
            result = do_publish(args)
        else:
            raise CliError(f"Unsupported command: {args.command}")

        emit_result(result, json_output=json_output)
        return 0
    except CliError as error:
        emit_error(error, json_output=json_output)
        return error.exit_code


if __name__ == "__main__":
    sys.exit(main())
