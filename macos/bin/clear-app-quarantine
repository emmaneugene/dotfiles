#!/usr/bin/env python3
"""Clears Gatekeeper quarantine flags from desktop applications."""

import subprocess
import sys
from pathlib import Path


def has_quarantine(path: Path) -> bool:
    """Check if path has the com.apple.quarantine attribute."""
    try:
        subprocess.run(
            ["xattr", "-p", "com.apple.quarantine", str(path)],
            check=True,
            capture_output=True,
            text=True,
        )
        return True
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or "").strip()
        if "No such xattr" in stderr:
            return False
        print(f"  ✗ Failed to check {path.name}: {stderr}", file=sys.stderr)
        return False


def clear_quarantine(path: Path) -> bool:
    """Remove the com.apple.quarantine attribute from a path."""
    try:
        subprocess.run(
            ["xattr", "-dr", "com.apple.quarantine", str(path)],
            check=True,
            capture_output=True,
            text=True,
        )
        return True
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or "").strip()
        print(f"  ✗ Failed to clear {path.name}: {stderr}", file=sys.stderr)
        return False


def main() -> None:
    dirs = [Path("/Applications"), Path.home() / "Applications"]
    count = 0

    for base in dirs:
        if not base.exists():
            continue

        for app in base.glob("*.app"):
            if has_quarantine(app):
                if clear_quarantine(app):
                    print(f"  ✓ {app.name}")
                    count += 1

    if count == 0:
        print("No quarantined apps found.")
    else:
        print(f"Cleared {count} app(s).")


if __name__ == "__main__":
    main()
