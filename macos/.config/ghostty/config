# Docs: https://ghostty.org/docs/config/reference
# Preview: https://ghostty.zerebos.com/app/import-export

clipboard-read = allow
clipboard-write = allow
confirm-close-surface = false
copy-on-select = clipboard
cursor-style = block
font-family = Hack Nerd Font Mono
font-feature = -calt, -liga, -dlig
font-size = 12
font-thicken = true
keybind = cmd+backspace=text:\x15
keybind = cmd+backslash=new_split:right
keybind = cmd+shift+backslash=new_split:down
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
macos-option-as-alt = true
quit-after-last-window-closed = true
shell-integration-features = no-cursor
