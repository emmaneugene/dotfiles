{
  "$schema": "https:\/\/schema.linearmouse.app\/0.10.4",
  "schemes": [
    {
      "if": {
        "device": {
          "category": "trackpad"
        }
      },
      "scrolling": {
        "acceleration": {
          "vertical": 1
        }
      }
    },
    {
      "if": {
        "device": {
          "category": "mouse"
        }
      },
      "pointer": {
        "acceleration": 0.8,
        "disableAcceleration": true,
        "speed": 0.0689655172413792768
      },
      "scrolling": {
        "acceleration": 1,
        "distance": {
          "horizontal": 10,
          "vertical": "auto"
        },
        "reverse": {
          "vertical": false
        },
        "speed": 0
      }
    }
  ]
}
