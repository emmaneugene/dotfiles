{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "find *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "date *": "allow",
      "uname *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      "less *": "allow",
      "more *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "top *": "allow",
      "which *": "allow",
      "whereis *": "allow",
      "pwd": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "allow",
      "git checkout *": "allow",
      "git branch *": "allow",
      "git stash *": "allow",
      "git pull *": "allow",
      "git fetch *": "allow",
      "npm *": "allow",
      "bun *": "allow",
      "make *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "python *": "allow",
      "node *": "allow",
      "docker *": "allow",
      "docker-compose *": "allow"
    }
  }
}
