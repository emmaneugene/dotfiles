# duti settings — applied via: duti ~/.duti
# Format: app_id  UTI  role
# To change your default editor, update the app_id on each line.

# Catch-alls: all natively-typed plain text and source code
dev.zed.Zed    public.plain-text                   all
dev.zed.Zed    public.source-code                  all

# Data and config formats (native UTIs, don't conform to public.source-code)
dev.zed.Zed    net.daringfireball.markdown         all
dev.zed.Zed    public.json                         all
dev.zed.Zed    public.xml                          all
dev.zed.Zed    public.yaml                         all
dev.zed.Zed    public.toml                         all
dev.zed.Zed    org.iso.sql                         all
dev.zed.Zed    public.comma-separated-values-text  all
dev.zed.Zed    com.apple.log                       all
